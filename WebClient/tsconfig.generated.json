{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ES2020",
    "moduleResolution": "Bundler",
    "rootDir": "./generated-ts",
    "outDir": "./generated-js",
    "strict": false,
    "skipLibCheck": true,
    "declaration": false,
    "sourceMap": false,
    "noEmitOnError": false
  },
  "include": ["generated-ts/**/*.ts"]
}
